  "contextual": {
    "options": ["copy", "view"]
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:description": "Help documentation for CoordHub — NDIS Support Coordination software for Australian coordinators.",
      "canonical": "https://docs.coordhub.au"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "one-dark-pro"
      }
    },
    "eyebrows": "section"
  }
