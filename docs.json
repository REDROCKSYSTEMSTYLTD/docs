{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "CoordHub Help",
  "description": "Help documentation for CoordHub — NDIS Support Coordination software for Australian coordinators.",
  "colors": {
    "primary": "#9333ea",
    "light": "#c084fc",
    "dark": "#7e22ce"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://coordhub.au"
  },
  "appearance": {
    "default": "system"
  },
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "family": "Inter"
  },
  "background": {
    "decoration": "gradient"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@coordhub.au"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open CoordHub",
      "href": "https://app.coordhub.au"
    }
  },
  "navigation": {
